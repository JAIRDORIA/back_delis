{
  "openapi": "3.0.0",
  "info": {
    "title": "API DELIS",
    "description": "API REST para gestión contable e inventario del negocio DELIS. Pasabocas fritos.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "tags": [
    {
      "name": "Ventas",
      "description": "Gestión de ventas"
    },
    {
      "name": "Abonos",
      "description": "Gestión de abonos a ventas"
    },
    {
      "name": "Cortes",
      "description": "Gestión de cortes de caja"
    }
  ],
  "paths": {

    "/ventas/": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Listar todas las ventas",
        "description": "Retorna el listado completo de ventas con el nombre del cliente obtenido por JOIN con la tabla clientes.",
        "responses": {
          "200": {
            "description": "Lista de ventas obtenida correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id":              { "type": "integer", "example": 1 },
                      "cliente_id":      { "type": "integer", "example": 2 },
                      "nombre_cliente":  { "type": "string",  "example": "Juan Rodriguez" },
                      "corte_id":        { "type": "integer", "example": 1 },
                      "usuario_id":      { "type": "integer", "example": 1 },
                      "fecha_venta":     { "type": "string",  "example": "2026-03-21 10:30:00" },
                      "fecha_entrega":   { "type": "string",  "example": "2026-03-25" },
                      "total":           { "type": "number",  "example": 42000.0 },
                      "total_abonado":   { "type": "number",  "example": 20000.0 },
                      "saldo_pendiente": { "type": "number",  "example": 22000.0 },
                      "estado":          { "type": "string",  "example": "pendiente" }
                    }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      },

      "post": {
        "tags": ["Ventas"],
        "summary": "Registrar una nueva venta",
        "description": "Crea una nueva venta. La fecha_venta, total_abonado y saldo_pendiente son asignados automaticamente por el servidor y los triggers. El campo total_abonado inicia en 0 y solo se actualiza mediante abonos.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cliente_id", "corte_id", "usuario_id", "fecha_entrega", "total"],
                "properties": {
                  "cliente_id":    { "type": "integer", "example": 2,            "description": "Debe existir en clientes y estar activo" },
                  "corte_id":      { "type": "integer", "example": 1,            "description": "No puede ser un corte cerrado" },
                  "usuario_id":    { "type": "integer", "example": 1,            "description": "Debe existir y estar activo" },
                  "fecha_entrega": { "type": "string",  "example": "25/03/2026", "description": "Formato DD/MM/YYYY. No puede ser fecha pasada" },
                  "total":         { "type": "number",  "example": 42000,        "description": "Debe ser mayor a 0" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Venta registrada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "venta registrada" },
                    "datos": {
                      "type": "object",
                      "properties": {
                        "id":              { "type": "integer", "example": 4 },
                        "cliente_id":      { "type": "integer", "example": 2 },
                        "nombre_cliente":  { "type": "string",  "example": "Juan Rodriguez" },
                        "corte_id":        { "type": "integer", "example": 1 },
                        "usuario_id":      { "type": "integer", "example": 1 },
                        "fecha_venta":     { "type": "string",  "example": "2026-03-21 10:30:00" },
                        "fecha_entrega":   { "type": "string",  "example": "2026-03-25" },
                        "total":           { "type": "number",  "example": 42000.0 },
                        "total_abonado":   { "type": "number",  "example": 0.0 },
                        "saldo_pendiente": { "type": "number",  "example": 42000.0 },
                        "estado":          { "type": "string",  "example": "pendiente" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Campos faltantes o vacios, total <= 0, formato de fecha incorrecto, fecha pasada, corte cerrado" },
          "404": { "description": "Cliente, corte o usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/ventas/{id}": {
      "put": {
        "tags": ["Ventas"],
        "summary": "Actualizar una venta",
        "description": "Actualiza uno o varios campos de una venta. Solo funciona si la venta esta en estado pendiente. El id va en la URL. Se envia unicamente el campo que se quiere cambiar, los demas se mantienen igual.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID de la venta a actualizar",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fecha_entrega": { "type": "string", "example": "30/03/2026", "description": "Formato DD/MM/YYYY. Opcional" },
                  "total":         { "type": "number", "example": 50000,        "description": "Debe ser mayor a 0. Opcional" },
                  "estado":        { "type": "string", "example": "entregada",  "description": "Valores validos: pendiente, entregada, anulada. Opcional" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Venta actualizada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "venta actualizada" },
                    "datos":   { "type": "object"  }
                  }
                }
              }
            }
          },
          "400": { "description": "La venta no esta pendiente, estado invalido, total <= 0, fecha incorrecta o pasada" },
          "404": { "description": "La venta con ese id no existe" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/ventas/{id}/anulacion": {
      "put": {
        "tags": ["Ventas"],
        "summary": "Anular una venta",
        "description": "Cambia el estado de la venta a anulada. Activa el trigger que devuelve stock al inventario y registra el egreso en movimientos_caja. Solo funciona para ventas del corte actual o futuro. No requiere body.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID de la venta a anular",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Venta anulada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "venta anulada correctamente" },
                    "datos":   { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "description": "La venta ya esta anulada, ya fue entregada, o pertenece a un corte cerrado" },
          "404": { "description": "La venta con ese id no existe" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/abonos/": {
      "get": {
        "tags": ["Abonos"],
        "summary": "Listar todos los abonos",
        "description": "Retorna el listado completo de abonos registrados en el sistema.",
        "responses": {
          "200": {
            "description": "Lista de abonos obtenida correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id":          { "type": "integer", "example": 1 },
                      "venta_id":    { "type": "integer", "example": 1 },
                      "corte_id":    { "type": "integer", "example": 1 },
                      "usuario_id":  { "type": "integer", "example": 1 },
                      "monto":       { "type": "number",  "example": 20000.0 },
                      "fecha":       { "type": "string",  "example": "2026-03-21" },
                      "observacion": { "type": "string",  "example": "nequi" },
                      "medio_pago": { "type": "string", "example": "efectivo" }
                    }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      },

      "post": {
        "tags": ["Abonos"],
        "summary": "Registrar un nuevo abono",
        "description": "Registra un abono sobre una venta existente. El trigger trg_abono_insert actualiza automaticamente total_abonado y saldo_pendiente de la venta correspondiente.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["venta_id", "corte_id", "usuario_id", "monto", "fecha","medio_pago"],
                "properties": {
                  "venta_id":    { "type": "integer", "example": 1,            "description": "Debe existir y no estar entregada ni anulada" },
                  "corte_id":    { "type": "integer", "example": 1,            "description": "No puede ser un corte cerrado" },
                  "usuario_id":  { "type": "integer", "example": 1,            "description": "Debe existir y estar activo" },
                  "monto":       { "type": "number",  "example": 15000,        "description": "Debe ser mayor a 0 y no superar el saldo_pendiente" },
                  "fecha":       { "type": "string",  "example": "21/03/2026", "description": "Formato DD/MM/YYYY. No puede ser fecha pasada" },
                  "observacion": { "type": "string",  "example": "nequi",      "description": "Opcional. Si no se envia se guarda como null" },
                  "medio_pago" : {"type ": "string", "example" : "efectivo",   "description": "valores validos: efecivo,transferencia,otro" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Abono registrado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "abono registrado" },
                    "datos": {
                      "type": "object",
                      "properties": {
                        "id":          { "type": "integer", "example": 4 },
                        "venta_id":    { "type": "integer", "example": 1 },
                        "corte_id":    { "type": "integer", "example": 1 },
                        "usuario_id":  { "type": "integer", "example": 1 },
                        "monto":       { "type": "number",  "example": 15000.0 },
                        "fecha":       { "type": "string",  "example": "2026-03-21" },
                        "observacion": { "type": "string",  "example": "vueltos" },
                        "medio_pago": { "type": "string", "example": "efectivo" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Campos faltantes, monto <= 0, monto supera saldo pendiente, venta entregada o anulada, corte cerrado, fecha incorrecta o pasada" },
          "404": { "description": "Venta, corte o usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/abonos/{id}": {
      "put": {
        "tags": ["Abonos"],
        "summary": "Actualizar un abono",
        "description": "Actualiza monto, fecha u observacion de un abono. Recalcula automaticamente el total_abonado de la venta con la diferencia entre el monto anterior y el nuevo. Solo funciona si la venta asociada esta pendiente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID del abono a actualizar",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["monto", "fecha","medio_pago"],
                "properties": {
                  "monto":       { "type": "number", "example": 20000, "description": "Nuevo monto. No puede superar saldo_pendiente + monto_actual" },
                  "fecha":       { "type": "string", "example": "22/03/2026", "description": "Formato DD/MM/YYYY. No puede ser fecha pasada" },
                  "observacion": { "type": "string", "example": "Pago transferencia", "description": "Opcional" },
                  "medio_pago" : {"type ": "string", "example" : "efectivo",   "description": "valores validos: efecivo,transferencia,otro" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Abono actualizado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "abono actualizado" },
                    "datos":   { "type": "object" },
                    "medio_pago": { "type": "string", "example": "efectivo" }
                  }
                }
              }
            }
          },
          "400": { "description": "Monto invalido, fecha incorrecta, venta no pendiente" },
          "404": { "description": "Abono no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },

      "delete": {
        "tags": ["Abonos"],
        "summary": "Eliminar un abono",
        "description": "Elimina fisicamente un abono. El trigger trg_abono_delete revierte automaticamente el total_abonado en la venta. Solo se pueden eliminar abonos del corte actual y cuya venta este pendiente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID del abono a eliminar",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Abono eliminado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "abono 1 eliminado correctamente" }
                  }
                }
              }
            }
          },
          "400": { "description": "La venta no esta pendiente o el abono no pertenece al corte actual" },
          "404": { "description": "Abono o venta no encontrada" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/cortes/": {
      "get": {
        "tags": ["Cortes"],
        "summary": "Listar todos los cortes",
        "description": "Retorna el listado completo de cortes ordenados por numero ascendente.",
        "responses": {
          "200": {
            "description": "Lista de cortes obtenida correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id":            { "type": "integer", "example": 1 },
                      "numero":        { "type": "integer", "example": 1 },
                      "fecha_inicio":  { "type": "string",  "example": "2026-03-21 08:00:00" },
                      "fecha_cierre":  { "type": "string",  "example": "2026-03-21 14:00:00" },
                      "estado":        { "type": "string",  "example": "cerrado" },
                      "saldo_inicial": { "type": "number",  "example": 0.0 }
                    }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/cortes/iniciar": {
      "post": {
        "tags": ["Cortes"],
        "summary": "Iniciar primer corte",
        "description": "Crea el primer corte del sistema. Solo funciona una vez cuando no existe ningun corte registrado. Crea automaticamente el corte 1 con estado abierto y el corte 2 con estado futuro. No requiere body.",
        "responses": {
          "201": {
            "description": "Primer corte iniciado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "primer corte iniciado correctamente" },
                    "datos": {
                      "type": "object",
                      "properties": {
                        "id":            { "type": "integer", "example": 1 },
                        "numero":        { "type": "integer", "example": 1 },
                        "fecha_inicio":  { "type": "string",  "example": "2026-03-21 08:00:00" },
                        "fecha_cierre":  { "type": "string",  "example": null },
                        "estado":        { "type": "string",  "example": "abierto" },
                        "saldo_inicial": { "type": "number",  "example": 0.0 }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Ya existen cortes registrados, no se puede iniciar de nuevo" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/cortes/cerrar": {
      "post": {
        "tags": ["Cortes"],
        "summary": "Cerrar corte actual",
        "description": "Cierra el corte actualmente abierto y activa el corte futuro. Calcula automaticamente el saldo heredado de abonos anticipados y lo asigna como saldo_inicial del nuevo corte. Crea un nuevo corte futuro vacio. No requiere body.",
        "responses": {
          "200": {
            "description": "Corte cerrado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "corte #1 cerrado correctamente, corte #2 ahora esta abierto" },
                    "datos": {
                      "type": "object",
                      "properties": {
                        "id":            { "type": "integer", "example": 2 },
                        "numero":        { "type": "integer", "example": 2 },
                        "fecha_inicio":  { "type": "string",  "example": "2026-03-21 14:00:00" },
                        "fecha_cierre":  { "type": "string",  "example": null },
                        "estado":        { "type": "string",  "example": "abierto" },
                        "saldo_inicial": { "type": "number",  "example": 35000.0 }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "No existe corte abierto o no existe corte futuro" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/cortes/{id}": {
      "put": {
        "tags": ["Cortes"],
        "summary": "Actualizar estado de un corte",
        "description": "Actualiza el estado de un corte. Uso exclusivo administrativo para corregir errores. No usar en el flujo normal del negocio. No se puede modificar un corte cerrado.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID del corte a actualizar",
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["estado"],
                "properties": {
                  "estado": { "type": "string", "example": "futuro", "description": "Valores validos: abierto, futuro. No se puede poner cerrado" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Corte actualizado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensaje": { "type": "string", "example": "corte actualizado" },
                    "datos":   { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "description": "Estado invalido o el corte ya esta cerrado" },
          "404": { "description": "Corte no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    }

  }
}

