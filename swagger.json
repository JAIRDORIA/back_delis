{
  "openapi": "3.0.0",
  "info": {
    "title": "API DELIS",
    "description": "API REST para gestión contable e inventario del negocio DELIS. Pasabocas fritos.",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://localhost:5000" }],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenido desde POST /auth/login"
      }
    },
    "parameters": {
      "pagina": {
        "name": "pagina", "in": "query", "required": false,
        "description": "Número de página (por defecto 1)",
        "schema": { "type": "integer", "example": 1 }
      },
      "limite": {
        "name": "limite", "in": "query", "required": false,
        "description": "Registros por página (por defecto 20)",
        "schema": { "type": "integer", "example": 20 }
      }
    }
  },
  "tags": [
    { "name": "Auth",        "description": "Autenticación y configuración inicial" },
    { "name": "Usuarios",    "description": "Gestión de usuarios del sistema" },
    { "name": "Productos",   "description": "Gestión de productos" },
    { "name": "Inventario",  "description": "Gestión de inventario" },
    { "name": "Producciones","description": "Registro de producciones" },
    { "name": "Ventas",      "description": "Gestión de ventas" },
    { "name": "Abonos",      "description": "Gestión de abonos a ventas" },
    { "name": "Cortes",      "description": "Gestión de cortes de caja" },
    { "name": "Clientes",    "description": "Gestión de clientes" }
  ],
  "paths": {

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Iniciar sesión",
        "description": "Verifica credenciales y retorna un token JWT.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["username","password"],
            "properties": {
              "username": { "type": "string", "example": "cperez" },
              "password": { "type": "string", "example": "clave123" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Login exitoso. Retorna el token JWT.", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "access_token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." },
              "token_type":   { "type": "string", "example": "bearer" },
              "usuario": { "type": "object", "properties": {
                "id":       { "type": "integer", "example": 1 },
                "nombre":   { "type": "string",  "example": "Carlos Pérez" },
                "username": { "type": "string",  "example": "cperez" },
                "rol":      { "type": "string",  "example": "admin" }
              }}
            }
          }}}},
          "400": { "description": "Faltan credenciales" },
          "401": { "description": "Credenciales inválidas" }
        }
      }
    },

    "/usuarios/setup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrar primer administrador",
        "description": "Crea el primer usuario administrador. Solo funciona si no existe ningún admin. No requiere token JWT.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["nombre","username","password","rol"],
            "properties": {
              "nombre":   { "type": "string", "example": "Carlos Pérez",  "description": "Entre 3 y 100 caracteres, solo letras" },
              "username": { "type": "string", "example": "cperez",        "description": "Entre 4 y 50 caracteres" },
              "password": { "type": "string", "example": "clave123",      "description": "Entre 6 y 50 caracteres" },
              "rol":      { "type": "string", "example": "admin",         "description": "Debe ser exactamente admin" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Administrador inicial creado exitosamente" },
          "400": { "description": "Campos faltantes, rol distinto de admin o username duplicado" },
          "403": { "description": "Ya existe un administrador registrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/usuarios/check-setup": {
      "get": {
        "tags": ["Auth"],
        "summary": "Verificar si el sistema está configurado",
        "description": "Indica si ya existe un administrador activo. No requiere token JWT.",
        "responses": {
          "200": { "description": "Estado del sistema", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "setup_completado": { "type": "boolean", "example": true },
              "mensaje":          { "type": "string",  "example": "Sistema configurado" }
            }
          }}}}
        }
      }
    },

    "/usuarios/": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Listar usuarios activos",
        "description": "Retorna usuarios con activo = 1 de forma paginada. No incluye password_hash.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/pagina" },
          { "$ref": "#/components/parameters/limite" }
        ],
        "responses": {
          "200": { "description": "Lista paginada de usuarios", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "datos": { "type": "array", "items": { "type": "object", "properties": {
                "id":         { "type": "integer", "example": 1 },
                "nombre":     { "type": "string",  "example": "Carlos Pérez" },
                "username":   { "type": "string",  "example": "cperez" },
                "rol":        { "type": "string",  "example": "admin" },
                "activo":     { "type": "integer", "example": 1 },
                "created_at": { "type": "string",  "example": "2026-03-24 09:01:45" },
                "updated_at": { "type": "string",  "example": "2026-03-24 09:01:45" }
              }}},
              "total":         { "type": "integer", "example": 5 },
              "pagina":        { "type": "integer", "example": 1 },
              "limite":        { "type": "integer", "example": 20 },
              "total_paginas": { "type": "integer", "example": 1 }
            }
          }}}},
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Usuarios"],
        "summary": "Registrar un nuevo usuario",
        "description": "La contraseña se envía en texto plano y se almacena como hash bcrypt.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["nombre","username","password","rol"],
            "properties": {
              "nombre":   { "type": "string", "example": "Ana Gómez",  "description": "Entre 3 y 100 caracteres, solo letras" },
              "username": { "type": "string", "example": "agomez",     "description": "Entre 4 y 50 caracteres" },
              "password": { "type": "string", "example": "clave123",   "description": "Entre 6 y 50 caracteres" },
              "rol":      { "type": "string", "example": "cajero",     "description": "Valores válidos: admin, cajero" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Usuario registrado correctamente" },
          "400": { "description": "Campos faltantes, username duplicado o rol inválido" },
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/usuarios/{id}": {
      "get": {
        "tags": ["Usuarios"], "summary": "Obtener un usuario por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "responses": {
          "200": { "description": "Usuario encontrado" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Usuario no encontrado" }
        }
      },
      "put": {
        "tags": ["Usuarios"],
        "summary": "Actualizar un usuario",
        "description": "Si no se envía password se conserva la actual. No actualiza si no hay cambios reales.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["nombre","username","rol"],
            "properties": {
              "nombre":   { "type": "string", "example": "Ana Gómez" },
              "username": { "type": "string", "example": "agomez2" },
              "password": { "type": "string", "example": "nuevaClave123", "description": "Opcional" },
              "rol":      { "type": "string", "example": "admin", "description": "Valores válidos: admin, cajero" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Usuario actualizado correctamente" },
          "400": { "description": "Sin cambios, campos inválidos o username duplicado" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "delete": {
        "tags": ["Usuarios"],
        "summary": "Desactivar un usuario (soft delete)",
        "description": "Pone activo = 0. El usuario con id = 1 no puede desactivarse.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 2 } }],
        "responses": {
          "200": { "description": "Usuario desactivado correctamente" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/productos/": {
      "get": {
        "tags": ["Productos"],
        "summary": "Listar productos activos",
        "description": "Retorna productos con activo = 1 de forma paginada.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/pagina" },
          { "$ref": "#/components/parameters/limite" }
        ],
        "responses": {
          "200": { "description": "Lista paginada de productos", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "datos": { "type": "array", "items": { "type": "object", "properties": {
                "id":                   { "type": "integer", "example": 1 },
                "nombre":               { "type": "string",  "example": "Bandeja de deditos" },
                "descripcion":          { "type": "string",  "example": "22 unidades de deditos" },
                "precio_venta":         { "type": "number",  "example": 14000 },
                "unidades_por_bandeja": { "type": "integer", "example": 22 },
                "activo":               { "type": "integer", "example": 1 },
                "created_at":           { "type": "string",  "example": "2026-03-24 09:02:57" },
                "updated_at":           { "type": "string",  "example": "2026-03-24 09:02:57" }
              }}},
              "total":         { "type": "integer", "example": 10 },
              "pagina":        { "type": "integer", "example": 1 },
              "limite":        { "type": "integer", "example": 20 },
              "total_paginas": { "type": "integer", "example": 1 }
            }
          }}}},
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Productos"], "summary": "Registrar un nuevo producto",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["nombre","descripcion","precio_venta","unidades_por_bandeja"],
            "properties": {
              "nombre":               { "type": "string",  "example": "Bandeja de deditos",    "description": "Entre 3 y 150 caracteres" },
              "descripcion":          { "type": "string",  "example": "22 unidades de deditos", "description": "Entre 4 y 255 caracteres" },
              "precio_venta":         { "type": "number",  "example": 14000,                    "description": "Debe ser mayor a 0" },
              "unidades_por_bandeja": { "type": "integer", "example": 22,                       "description": "Debe ser mayor a 0" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Producto registrado correctamente" },
          "400": { "description": "Campos faltantes, nombre duplicado o valores inválidos" },
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/productos/{id}": {
      "get": {
        "tags": ["Productos"], "summary": "Obtener un producto por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "responses": {
          "200": { "description": "Producto encontrado" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Producto no encontrado" }
        }
      },
      "put": {
        "tags": ["Productos"],
        "summary": "Actualizar un producto",
        "description": "Todos los campos son opcionales. No actualiza si no hay cambios reales.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "nombre":               { "type": "string",  "example": "Bandeja especial",    "description": "Opcional" },
              "descripcion":          { "type": "string",  "example": "25 unidades grandes", "description": "Opcional" },
              "precio_venta":         { "type": "number",  "example": 16000,                 "description": "Opcional. Mayor a 0" },
              "unidades_por_bandeja": { "type": "integer", "example": 25,                    "description": "Opcional. Mayor a 0" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Producto actualizado correctamente" },
          "400": { "description": "Sin cambios o valores inválidos" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Producto no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "delete": {
        "tags": ["Productos"],
        "summary": "Desactivar un producto (soft delete)",
        "description": "Pone activo = 0. No se elimina físicamente.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "responses": {
          "200": { "description": "Producto desactivado correctamente" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Producto no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/inventarios/": {
      "get": {
        "tags": ["Inventario"],
        "summary": "Listar inventario",
        "description": "Retorna inventario paginado de productos activos. Incluye nombre del producto por JOIN.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/pagina" },
          { "$ref": "#/components/parameters/limite" }
        ],
        "responses": {
          "200": { "description": "Inventario paginado", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "datos": { "type": "array", "items": { "type": "object", "properties": {
                "id":               { "type": "integer", "example": 1 },
                "producto_id":      { "type": "integer", "example": 1 },
                "nombre_producto":  { "type": "string",  "example": "Bandeja de deditos" },
                "stock_actual":     { "type": "integer", "example": 10 },
                "unidades_sueltas": { "type": "integer", "example": 0 },
                "stock_minimo":     { "type": "integer", "example": 5 },
                "updated_at":       { "type": "string",  "example": "2026-03-24 09:04:00" }
              }}},
              "total":         { "type": "integer", "example": 8 },
              "pagina":        { "type": "integer", "example": 1 },
              "limite":        { "type": "integer", "example": 20 },
              "total_paginas": { "type": "integer", "example": 1 }
            }
          }}}},
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Inventario"],
        "summary": "Registrar inventario para un producto",
        "description": "Crea el registro inicial. stock_actual inicia en 0 y lo manejan los triggers.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["producto_id"],
            "properties": {
              "producto_id": { "type": "integer", "example": 1, "description": "Debe existir en productos y no tener inventario previo" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Inventario registrado correctamente" },
          "400": { "description": "Producto no existe o ya tiene inventario" },
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/inventarios/bajo-stock": {
      "get": {
        "tags": ["Inventario"],
        "summary": "Productos bajo stock mínimo",
        "description": "Retorna productos con stock_actual <= stock_minimo. Usa la vista v_productos_bajo_stock.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de productos bajo stock", "content": { "application/json": { "schema": {
            "type": "array",
            "items": { "type": "object", "properties": {
              "id":           { "type": "integer", "example": 2 },
              "nombre":       { "type": "string",  "example": "Bandeja de empanadas" },
              "stock_actual": { "type": "integer", "example": 3 },
              "stock_minimo": { "type": "integer", "example": 5 }
            }}
          }}}},
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/inventarios/{id}": {
      "get": {
        "tags": ["Inventario"], "summary": "Obtener inventario por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "responses": {
          "200": { "description": "Inventario encontrado" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Inventario no encontrado" }
        }
      },
      "put": {
        "tags": ["Inventario"],
        "summary": "Actualizar stock mínimo",
        "description": "Solo se puede editar stock_minimo. El stock_actual lo manejan los triggers.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["stock_minimo"],
            "properties": {
              "stock_minimo": { "type": "integer", "example": 10, "description": "Mayor o igual a 0" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "Stock mínimo actualizado correctamente" },
          "400": { "description": "Sin cambios o valor inválido" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Inventario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/producciones/": {
      "get": {
        "tags": ["Producciones"],
        "summary": "Listar producciones",
        "description": "Retorna producciones paginadas con nombre del producto y usuario.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/pagina" },
          { "$ref": "#/components/parameters/limite" }
        ],
        "responses": {
          "200": { "description": "Lista paginada de producciones", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "datos": { "type": "array", "items": { "type": "object", "properties": {
                "id":               { "type": "integer", "example": 1 },
                "producto_id":      { "type": "integer", "example": 1 },
                "nombre_producto":  { "type": "string",  "example": "Bandeja de deditos" },
                "cantidad":         { "type": "integer", "example": 10 },
                "usuario_id":       { "type": "integer", "example": 1 },
                "nombre_usuario":   { "type": "string",  "example": "Carlos Pérez" },
                "fecha":            { "type": "string",  "example": "2026-03-21" },
                "observacion":      { "type": "string",  "example": "Producción del lunes" },
                "created_at":       { "type": "string",  "example": "2026-03-21 08:00:00" }
              }}},
              "total":         { "type": "integer", "example": 3 },
              "pagina":        { "type": "integer", "example": 1 },
              "limite":        { "type": "integer", "example": 20 },
              "total_paginas": { "type": "integer", "example": 1 }
            }
          }}}},
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Producciones"],
        "summary": "Registrar una producción",
        "description": "Registra una producción. El trigger trg_produccion_insert aumenta automáticamente el stock_actual en inventario.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["producto_id","cantidad","usuario_id","fecha"],
            "properties": {
              "producto_id": { "type": "integer", "example": 1,              "description": "Debe existir y estar activo" },
              "cantidad":    { "type": "integer", "example": 10,             "description": "Debe ser mayor a 0" },
              "usuario_id":  { "type": "integer", "example": 1,              "description": "Debe existir y estar activo" },
              "fecha":       { "type": "string",  "example": "20/05/2026",   "description": "Formato DD/MM/YYYY" },
              "observacion": { "type": "string",  "example": "Producción del lunes", "description": "Opcional" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Producción registrada correctamente", "content": { "application/json": { "schema": {
            "type": "object",
            "properties": {
              "mensaje": { "type": "string", "example": "Producción registrada" },
              "datos": { "type": "object", "properties": {
                "id":          { "type": "integer", "example": 4 },
                "producto_id": { "type": "integer", "example": 1 },
                "cantidad":    { "type": "integer", "example": 10 },
                "usuario_id":  { "type": "integer", "example": 1 },
                "fecha":       { "type": "string",  "example": "2026-05-20" },
                "observacion": { "type": "string",  "example": "Producción del lunes" },
                "created_at":  { "type": "string",  "example": "2026-05-20 08:00:00" }
              }}
            }
          }}}},
          "400": { "description": "Campos faltantes, cantidad <= 0 o formato de fecha incorrecto" },
          "401": { "description": "Token inválido o no enviado" },
          "404": { "description": "Producto o usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
