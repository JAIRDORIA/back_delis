{
  "openapi": "3.0.0",
  "info": {
    "title": "API DELIS",
    "description": "API REST para gestión contable e inventario del negocio DELIS. Pasabocas fritos.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtenido desde POST /auth/login"
      }
    }
  },
  "tags": [
    { "name": "Auth",        "description": "Autenticación y configuración inicial del sistema" },
    { "name": "Usuarios",    "description": "Gestión de usuarios del sistema" },
    { "name": "Productos",   "description": "Gestión de productos" },
    { "name": "Inventario",  "description": "Gestión de inventario" },
    { "name": "Ventas",      "description": "Gestión de ventas" },
    { "name": "Abonos",      "description": "Gestión de abonos a ventas" },
    { "name": "Cortes",      "description": "Gestión de cortes de caja" },
    { "name": "Clientes",    "description": "Gestión de clientes" },
    { "name": "Proveedores", "description": "Gestión de proveedores" },
    { "name": "Compras",     "description": "Gestión de compras a proveedores" }
  ],
  "paths": {

    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Iniciar sesión",
        "description": "Verifica las credenciales del usuario y retorna un token JWT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string", "example": "cperez" },
                  "password": { "type": "string", "example": "clave123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso. Retorna el token JWT.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": { "type": "string", "example": "eyJhbGci..." },
                    "token_type":   { "type": "string", "example": "bearer" },
                    "usuario": {
                      "type": "object",
                      "properties": {
                        "id":       { "type": "integer", "example": 1 },
                        "nombre":   { "type": "string",  "example": "Carlos Pérez" },
                        "username": { "type": "string",  "example": "cperez" },
                        "rol":      { "type": "string",  "example": "admin" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Faltan credenciales" },
          "401": { "description": "Credenciales inválidas" }
        }
      }
    },

    "/api/usuarios/setup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrar primer administrador",
        "description": "Crea el primer usuario administrador. Solo funciona si no existe ningún admin. No requiere token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "username", "password", "rol"],
                "properties": {
                  "nombre":   { "type": "string", "example": "Carlos Pérez" },
                  "username": { "type": "string", "example": "cperez" },
                  "password": { "type": "string", "example": "clave123" },
                  "rol":      { "type": "string", "example": "admin", "description": "Debe ser exactamente 'admin'" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Administrador inicial creado exitosamente" },
          "400": { "description": "Campos faltantes, rol inválido o username duplicado" },
          "403": { "description": "Ya existe un administrador registrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/api/usuarios/check-setup": {
      "get": {
        "tags": ["Auth"],
        "summary": "Verificar si el sistema está configurado",
        "responses": {
          "200": {
            "description": "Estado del sistema",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "setup_completado": { "type": "boolean", "example": true },
                    "mensaje":          { "type": "string",  "example": "Sistema configurado" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/usuarios/": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Listar usuarios activos",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "pagina", "in": "query", "schema": { "type": "integer", "example": 1 } },
          { "name": "limite", "in": "query", "schema": { "type": "integer", "example": 20 } }
        ],
        "responses": {
          "200": { "description": "Lista de usuarios obtenida correctamente" },
          "401": { "description": "Token inválido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Usuarios"],
        "summary": "Registrar un nuevo usuario",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "username", "password", "rol"],
                "properties": {
                  "nombre":   { "type": "string", "example": "Ana Gómez" },
                  "username": { "type": "string", "example": "agomez" },
                  "password": { "type": "string", "example": "clave123" },
                  "rol":      { "type": "string", "example": "cajero", "description": "admin o cajero" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario registrado correctamente" },
          "400": { "description": "Campos faltantes o inválidos" },
          "401": { "description": "Token inválido o no enviado" }
        }
      }
    },

    "/api/usuarios/{id}": {
      "get": {
        "tags": ["Usuarios"],
        "summary": "Obtener un usuario por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Usuario encontrado" },
          "404": { "description": "Usuario no encontrado" }
        }
      },
      "put": {
        "tags": ["Usuarios"],
        "summary": "Actualizar un usuario",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "username", "rol"],
                "properties": {
                  "nombre":   { "type": "string", "example": "Ana Gómez" },
                  "username": { "type": "string", "example": "agomez2" },
                  "password": { "type": "string", "example": "nuevaClave123", "description": "Opcional" },
                  "rol":      { "type": "string", "example": "admin" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Usuario actualizado correctamente" },
          "400": { "description": "Sin cambios o campos inválidos" },
          "404": { "description": "Usuario no encontrado" }
        }
      },
      "delete": {
        "tags": ["Usuarios"],
        "summary": "Desactivar un usuario (soft delete)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Usuario desactivado correctamente" },
          "404": { "description": "Usuario no encontrado" }
        }
      }
    },

    "/api/productos/": {
      "get": {
        "tags": ["Productos"],
        "summary": "Listar productos activos",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de productos obtenida correctamente" },
          "401": { "description": "Token inválido o no enviado" }
        }
      },
      "post": {
        "tags": ["Productos"],
        "summary": "Registrar un nuevo producto",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "descripcion", "precio_venta", "unidades_por_bandeja"],
                "properties": {
                  "nombre":               { "type": "string",  "example": "Bandeja de deditos" },
                  "descripcion":          { "type": "string",  "example": "22 unidades de deditos" },
                  "precio_venta":         { "type": "number",  "example": 14000 },
                  "unidades_por_bandeja": { "type": "integer", "example": 22 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Producto registrado correctamente" },
          "400": { "description": "Campos faltantes o inválidos" }
        }
      }
    },

    "/api/productos/{id}": {
      "get": {
        "tags": ["Productos"],
        "summary": "Obtener producto por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Producto encontrado" },
          "404": { "description": "Producto no encontrado" }
        }
      },
      "put": {
        "tags": ["Productos"],
        "summary": "Actualizar un producto",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre":               { "type": "string",  "example": "Bandeja especial" },
                  "descripcion":          { "type": "string",  "example": "25 unidades grandes" },
                  "precio_venta":         { "type": "number",  "example": 16000 },
                  "unidades_por_bandeja": { "type": "integer", "example": 25 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Producto actualizado correctamente" },
          "404": { "description": "Producto no encontrado" }
        }
      },
      "delete": {
        "tags": ["Productos"],
        "summary": "Desactivar un producto (soft delete)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Producto desactivado correctamente" },
          "404": { "description": "Producto no encontrado" }
        }
      }
    },

    "/api/inventarios/": {
      "get": {
        "tags": ["Inventario"],
        "summary": "Listar inventario",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Inventario obtenido correctamente" } }
      },
      "post": {
        "tags": ["Inventario"],
        "summary": "Registrar inventario para un producto",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["producto_id"],
                "properties": {
                  "producto_id": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Inventario registrado correctamente" },
          "400": { "description": "Producto no existe o ya tiene inventario" }
        }
      }
    },

    "/api/inventarios/bajo-stock": {
      "get": {
        "tags": ["Inventario"],
        "summary": "Productos bajo stock mínimo",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Lista de productos bajo stock" } }
      }
    },

    "/api/inventarios/{id}": {
      "get": {
        "tags": ["Inventario"],
        "summary": "Obtener inventario por ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Inventario encontrado" },
          "404": { "description": "Inventario no encontrado" }
        }
      },
      "put": {
        "tags": ["Inventario"],
        "summary": "Actualizar stock mínimo",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["stock_minimo"],
                "properties": {
                  "stock_minimo": { "type": "integer", "example": 10 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Stock mínimo actualizado correctamente" },
          "404": { "description": "Inventario no encontrado" }
        }
      }
    },

    "/ventas/": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Listar todas las ventas",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "pagina", "in": "query", "schema": { "type": "integer", "example": 1 } },
          { "name": "limite", "in": "query", "schema": { "type": "integer", "example": 20 } }
        ],
        "responses": { "200": { "description": "Lista de ventas obtenida correctamente" } }
      },
      "post": {
        "tags": ["Ventas"],
        "summary": "Registrar una nueva venta",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cliente_id", "corte_id", "usuario_id", "fecha_entrega", "total", "detalle"],
                "properties": {
                  "cliente_id":     { "type": "integer", "example": 2 },
                  "corte_id":       { "type": "integer", "example": 1 },
                  "usuario_id":     { "type": "integer", "example": 1 },
                  "fecha_entrega":  { "type": "string",  "example": "25/03/2026", "description": "Formato DD/MM/YYYY" },
                  "total":          { "type": "number",  "example": 40000 },
                  "detalle": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["producto_id", "nombre_producto", "cantidad", "precio_unitario"],
                      "properties": {
                        "producto_id":     { "type": "integer", "example": 1 },
                        "nombre_producto": { "type": "string",  "example": "Bandeja de deditos" },
                        "cantidad":        { "type": "integer", "example": 2 },
                        "precio_unitario": { "type": "number",  "example": 14000 }
                      }
                    }
                  },
                  "abono_inicial": {
                    "type": "object",
                    "description": "Opcional",
                    "properties": {
                      "monto":       { "type": "number", "example": 20000 },
                      "medio_pago":  { "type": "string", "example": "efectivo", "description": "efectivo, transferencia, otro" },
                      "observacion": { "type": "string", "example": "pago en caja" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Venta registrada correctamente" },
          "400": { "description": "Campos faltantes o inválidos" },
          "404": { "description": "Cliente, corte o usuario no encontrado" }
        }
      }
    },

    "/ventas/{id}": {
      "put": {
        "tags": ["Ventas"],
        "summary": "Actualizar una venta",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fecha_entrega": { "type": "string", "example": "30/03/2026" },
                  "total":         { "type": "number", "example": 50000 },
                  "estado":        { "type": "string", "example": "entregada", "description": "pendiente, entregada, anulada" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Venta actualizada correctamente" },
          "404": { "description": "Venta no encontrada" }
        }
      }
    },

    "/ventas/{id}/anulacion": {
      "put": {
        "tags": ["Ventas"],
        "summary": "Anular una venta",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Venta anulada correctamente" },
          "400": { "description": "La venta ya está anulada o entregada" },
          "404": { "description": "Venta no encontrada" }
        }
      }
    },

    "/ventas/{id}/comprobante": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Generar o consultar comprobante de venta",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Comprobante generado o consultado correctamente" },
          "404": { "description": "Venta no encontrada" }
        }
      }
    },

    "/abonos/": {
      "get": {
        "tags": ["Abonos"],
        "summary": "Listar todos los abonos",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Lista de abonos obtenida correctamente" } }
      },
      "post": {
        "tags": ["Abonos"],
        "summary": "Registrar un nuevo abono",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["venta_id", "corte_id", "usuario_id", "monto", "fecha", "medio_pago"],
                "properties": {
                  "venta_id":    { "type": "integer", "example": 1 },
                  "corte_id":   { "type": "integer", "example": 1 },
                  "usuario_id": { "type": "integer", "example": 1 },
                  "monto":      { "type": "number",  "example": 15000 },
                  "fecha":      { "type": "string",  "example": "21/03/2026", "description": "Formato DD/MM/YYYY" },
                  "medio_pago": { "type": "string",  "example": "efectivo", "description": "efectivo, transferencia, otro" },
                  "observacion":{ "type": "string",  "example": "nequi", "description": "Opcional" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Abono registrado correctamente" },
          "400": { "description": "Campos faltantes o monto inválido" },
          "404": { "description": "Venta, corte o usuario no encontrado" }
        }
      }
    },

    "/abonos/{id}": {
      "put": {
        "tags": ["Abonos"],
        "summary": "Actualizar un abono",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["monto", "fecha", "medio_pago"],
                "properties": {
                  "monto":       { "type": "number", "example": 20000 },
                  "fecha":       { "type": "string", "example": "22/03/2026" },
                  "medio_pago":  { "type": "string", "example": "efectivo" },
                  "observacion": { "type": "string", "example": "Pago transferencia", "description": "Opcional" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Abono actualizado correctamente" },
          "404": { "description": "Abono no encontrado" }
        }
      },
      "delete": {
        "tags": ["Abonos"],
        "summary": "Eliminar un abono",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Abono eliminado correctamente" },
          "404": { "description": "Abono no encontrado" }
        }
      }
    },

    "/cortes/": {
      "get": {
        "tags": ["Cortes"],
        "summary": "Listar todos los cortes",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Lista de cortes obtenida correctamente" } }
      }
    },

    "/cortes/iniciar": {
      "post": {
        "tags": ["Cortes"],
        "summary": "Iniciar primer corte",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "201": { "description": "Primer corte iniciado correctamente" },
          "400": { "description": "Ya existen cortes registrados" }
        }
      }
    },

    "/cortes/cerrar": {
      "post": {
        "tags": ["Cortes"],
        "summary": "Cerrar corte actual",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Corte cerrado correctamente" },
          "400": { "description": "No existe corte abierto o futuro" }
        }
      }
    },

    "/cortes/{id}": {
      "put": {
        "tags": ["Cortes"],
        "summary": "Actualizar estado de un corte",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["estado"],
                "properties": {
                  "estado": { "type": "string", "example": "futuro", "description": "abierto o futuro" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Corte actualizado correctamente" },
          "404": { "description": "Corte no encontrado" }
        }
      }
    },

    "/api/clientes/": {
      "get": {
        "tags": ["Clientes"],
        "summary": "Listar clientes",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Lista de clientes obtenida correctamente" } }
      },
      "post": {
        "tags": ["Clientes"],
        "summary": "Registrar cliente",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "telefono", "direccion", "email"],
                "properties": {
                  "nombre":    { "type": "string", "example": "Juan Rodriguez" },
                  "telefono":  { "type": "string", "example": "3001234567" },
                  "direccion": { "type": "string", "example": "Calle 10 #20-30" },
                  "email":     { "type": "string", "example": "juan@gmail.com" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Cliente registrado correctamente" },
