{
  "openapi": "3.0.0",
  "info": {
    "title": "API DELIS",
    "description": "API REST para gestión contable e inventario del negocio DELIS. Pasabocas fritos.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:4000",
      "description": "Servidor Local Flask"
    }
  ],
  "tags": [
    {
      "name": "Ventas",
      "description": "Gestión de ventas y estados"
    },
    {
      "name": "Abonos",
      "description": "Gestión de abonos a ventas"
    },
    {
      "name": "Cortes",
      "description": "Gestión de cortes de caja"
    }
  ],
  "paths": {
    "/ventas/": {
      "get": {
        "tags": [
          "Ventas"
        ],
        "summary": "Listar todas las ventas",
        "description": "Retorna el listado completo de ventas con el nombre del cliente obtenido por JOIN con la tabla clientes.",
        "responses": {
          "200": {
            "description": "Lista de ventas obtenida correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "integer",
                        "example": 1
                      },
                      "cliente_id": {
                        "type": "integer",
                        "example": 2
                      },
                      "nombre_cliente": {
                        "type": "string",
                        "example": "Juan Rodriguez"
                      },
                      "corte_id": {
                        "type": "integer",
                        "example": 1
                      },
                      "usuario_id": {
                        "type": "integer",
                        "example": 1
                      },
                      "fecha_venta": {
                        "type": "string",
                        "example": "2026-03-21 10:30:00"
                      },
                      "fecha_entrega": {
                        "type": "string",
                        "example": "2026-03-25"
                      },
                      "total": {
                        "type": "number",
                        "example": 42000
                      },
                      "total_abonado": {
                        "type": "number",
                        "example": 20000
                      },
                      "saldo_pendiente": {
                        "type": "number",
                        "example": 22000
                      },
                      "estado": {
                        "type": "string",
                        "example": "pendiente"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor"
          }
        }
      },
      "post": {
        "tags": [
          "Ventas"
        ],
        "summary": "Registrar una nueva venta",
        "description": "Crea una nueva venta. La fecha_venta, total_abonado y saldo_pendiente son asignados automáticamente por el servidor y los triggers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cliente_id",
                  "corte_id",
                  "usuario_id",
                  "fecha_entrega",
                  "total"
                ],
                "properties": {
                  "cliente_id": {
                    "type": "integer",
                    "example": 2
                  },
                  "corte_id": {
                    "type": "integer",
                    "example": 1
                  },
                  "usuario_id": {
                    "type": "integer",
                    "example": 1
                  },
                  "fecha_entrega": {
                    "type": "string",
                    "example": "25/03/2026"
                  },
                  "total": {
                    "type": "number",
                    "example": 42000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Venta registrada correctamente"
          },
          "400": {
            "description": "Datos inválidos o corte cerrado"
          }
        }
      }
    },
    "/ventas/{id}": {
      "put": {
        "tags": [
          "Ventas"
        ],
        "summary": "Actualizar una venta",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "estado": {
                    "type": "string",
                    "example": "entregada"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Actualizado"
          }
        }
      }
    },
    "/abonos/": {
      "get": {
        "tags": [
          "Abonos"
        ],
        "summary": "Listar todos los abonos",
        "responses": {
          "200": {
            "description": "Lista de abonos"
          }
        }
      },
      "post": {
        "tags": [
          "Abonos"
        ],
        "summary": "Registrar un nuevo abono",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "venta_id",
                  "monto",
                  "medio_pago"
                ],
                "properties": {
                  "venta_id": {
                    "type": "integer",
                    "example": 1
                  },
                  "monto": {
                    "type": "number",
                    "example": 5000
                  },
                  "medio_pago": {
                    "type": "string",
                    "example": "efectivo"
                  },
                  "observacion": {
                    "type": "string",
                    "example": "Pago parcial"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Abono registrado"
          }
        }
      }
    },
    "/cortes/cerrar": {
      "post": {
        "tags": [
          "Cortes"
        ],
        "summary": "Cerrar corte actual",
        "description": "Finaliza el corte abierto y habilita el siguiente.",
        "responses": {
          "200": {
            "description": "Corte cerrado con éxito"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}