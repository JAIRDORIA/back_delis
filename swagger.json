    "/ventas/": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Listar todas las ventas",
        "description": "Retorna el listado paginado de ventas con el nombre del cliente obtenido por JOIN.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/pagina" },
          { "$ref": "#/components/parameters/limite" }
        ],
        "responses": {
          "200": { "description": "Lista de ventas obtenida correctamente" },
          "400": { "description": "Pagina o limite invalido" },
          "401": { "description": "Token invalido o no enviado" },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "post": {
        "tags": ["Ventas"],
        "summary": "Registrar una nueva venta",
        "description": "Crea una nueva venta con su detalle de productos. El total_abonado y saldo_pendiente son calculados automáticamente por los triggers.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["cliente_id","corte_id","usuario_id","fecha_entrega","total","detalle"],
            "properties": {
              "cliente_id":    { "type": "integer", "example": 2 },
              "corte_id":      { "type": "integer", "example": 1 },
              "usuario_id":    { "type": "integer", "example": 1 },
              "fecha_entrega": { "type": "string",  "example": "25/03/2026", "description": "Formato DD/MM/YYYY" },
              "total":         { "type": "number",  "example": 40000 },
              "detalle": { "type": "array", "items": { "type": "object", "required": ["producto_id","nombre_producto","cantidad","precio_unitario"], "properties": {
                "producto_id":      { "type": "integer", "example": 1 },
                "nombre_producto":  { "type": "string",  "example": "Bandeja de deditos" },
                "cantidad":         { "type": "integer", "example": 2 },
                "precio_unitario":  { "type": "number",  "example": 14000 }
              }}},
              "abono_inicial": { "type": "object", "description": "Opcional", "properties": {
                "monto":       { "type": "number", "example": 20000 },
                "medio_pago":  { "type": "string", "example": "efectivo" },
                "observacion": { "type": "string", "example": "pago en caja" }
              }}
            }
          }}}
        },
        "responses": {
          "201": { "description": "Venta registrada correctamente" },
          "400": { "description": "Campos faltantes o inválidos" },
          "404": { "description": "Cliente, corte o usuario no encontrado" },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },

    "/ventas/{id}": {
      "put": {
        "tags": ["Ventas"], "summary": "Actualizar una venta",
        "description": "Solo si está pendiente. Se envía solo el campo a cambiar.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "example": 1 } }],
